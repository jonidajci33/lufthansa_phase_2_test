# ================================================================
# Planning Poker — Environment Variables
# Copy this file to .env and fill in actual values
# NEVER commit the .env file — it is in .gitignore
# ================================================================

# -- PostgreSQL ---------------------------------------------------
POSTGRES_DB=pp_identity
POSTGRES_USER=ppuser
POSTGRES_PASSWORD=pppass
POSTGRES_PORT=5432

# Logical databases (created by init-databases.sh)
IDENTITY_DB=pp_identity
ROOM_DB=pp_room
ESTIMATION_DB=pp_estimation
NOTIFICATION_DB=pp_notification
AUDIT_DB=pp_audit

# -- Redis --------------------------------------------------------
REDIS_PASSWORD=redispass
REDIS_PORT=6379

# -- Keycloak -----------------------------------------------------
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin
KC_PORT=8180
KC_DB_NAME=pp_keycloak

# -- Kafka --------------------------------------------------------
KAFKA_PORT=29092

# -- Application Services ----------------------------------------
GATEWAY_PORT=8080
IDENTITY_PORT=8081
ROOM_PORT=8082
ESTIMATION_PORT=8083
NOTIFICATION_PORT=8084
AUDIT_PORT=8085
SPRING_PROFILES_ACTIVE=local

# -- Observability ------------------------------------------------
JAEGER_UI_PORT=16686
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# -- Frontend URL -------------------------------------------------
FRONTEND_URL=http://localhost:3000

# -- Mailpit (local email testing) --------------------------------
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
# Production SMTP: override SMTP_HOST, SMTP_PORT, SMTP_USERNAME, SMTP_PASSWORD
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_AUTH=true
# SMTP_STARTTLS=true
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=<your-sendgrid-api-key>

# -- CI/CD (not used locally — stored in GitHub Secrets) ----------
# SONAR_TOKEN=<your-sonarqube-token>
# SONAR_HOST_URL=<your-sonarqube-url>

# -- Platform Admin User (created by keycloak-init on first start) -
# Set these to create an ADMIN user in Keycloak automatically.
# Leave blank to skip admin user creation.
# NEVER commit actual passwords — use .env (gitignored) or secrets manager.
# For testing purposes i will add them to example env file
PP_ADMIN_USERNAME=admin
PP_ADMIN_PASSWORD=changeme
PP_ADMIN_EMAIL=admin@planningpoker.local
