{
  "info": {
    "name": "Planning Poker Platform",
    "_postman_id": "pp-collection-001",
    "description": "API collection for the Planning Poker microservices platform.\n\nSetup:\n1. Import the 'Planning Poker Local' environment\n2. Obtain a token from Keycloak (use the 'Auth / Get Token (ROPC)' request)\n3. The token is auto-set in the collection variable {{access_token}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "keycloak_url",
      "value": "http://localhost:8180",
      "type": "string"
    },
    {
      "key": "realm",
      "value": "planning-poker",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication and token management via Keycloak",
      "item": [
        {
          "name": "Get Token (ROPC - dev only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', json.access_token);",
                  "    console.log('Token set successfully');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password" },
                { "key": "client_id", "value": "planning-poker-spa" },
                { "key": "username", "value": "testuser" },
                { "key": "password", "value": "testpass" },
                { "key": "scope", "value": "openid profile email" }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": ["{{keycloak_url}}"],
              "path": ["realms", "{{realm}}", "protocol", "openid-connect", "token"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "refresh_token" },
                { "key": "client_id", "value": "planning-poker-spa" },
                { "key": "refresh_token", "value": "{{refresh_token}}" }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": ["{{keycloak_url}}"],
              "path": ["realms", "{{realm}}", "protocol", "openid-connect", "token"]
            }
          }
        },
        {
          "name": "Get User Info",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/userinfo",
              "host": ["{{keycloak_url}}"],
              "path": ["realms", "{{realm}}", "protocol", "openid-connect", "userinfo"]
            }
          }
        }
      ]
    },
    {
      "name": "Identity Service",
      "description": "User profiles and account management",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/users/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "me"]
            }
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Jane Developer\",\n  \"avatarUrl\": \"https://example.com/avatar.png\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/users/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "me"]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/users/:userId",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", ":userId"],
              "variable": [
                { "key": "userId", "value": "" }
              ]
            }
          }
        }
      ]
    },
    {
